generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SurveyResponse {
  id              String    @id @default(uuid())
  patientName     String
  fatherName      String
  mrnNo           String
  dateOfProcedure DateTime
  contactNumber   String
  language        String
  answers         Json
  submittedAt     DateTime  @default(now())
  syncedAt        DateTime?
  deviceId        String?
  staffAssisted   Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String
  createdAt DateTime @default(now())
}
