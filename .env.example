# Copy this file to `.env.local` and fill in real values. Do NOT commit `.env.local`.

# Supabase project URL and public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key — SERVER ONLY, full DB access. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Prisma / PostgreSQL connection strings (Supabase pooler)
# Transaction pooler (port 6543) for runtime queries
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-region.pooler.supabase.com:6543/postgres
# Session pooler (port 5432) for migrations / schema introspection
DIRECT_URL=postgresql://postgres.your-project-ref:your-db-password@aws-region.pooler.supabase.com:5432/postgres
